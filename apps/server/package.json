{
    "name": "@atomassist/server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "lint": "echo \"lint not configured yet\"",
        "typecheck": "tsc --noEmit",
        "prisma:generate": "prisma generate --schema prisma/schema.prisma",
        "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
        "prisma:studio": "prisma studio --schema prisma/schema.prisma"
    },
    "dependencies": {
        "@atomassist/shared": "workspace:*",
        "@prisma/client": "^6.19.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.3",
        "socket.io": "^4.8.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.10.2",
        "prisma": "^6.19.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    }
}